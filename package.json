{
  "name": "activity-platform",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "build": "pnpm -r build",
    "bundle:renderer": "node scripts/bundle-renderer.mjs",
    "build:graph-kit": "node scripts/build-graph-kit.mjs",
    "upload:graph-kit": "node --env-file-if-exists=.env.r2 scripts/build-graph-kit.mjs --upload",
    "build:fonts": "node --env-file-if-exists=.env.r2 scripts/build-fonts.mjs",
    "build:mathlive-fonts": "node --env-file-if-exists=.env.r2 scripts/build-mathlive-fonts.mjs",
    "deploy:ingest": "supabase functions deploy ingest-submission --no-verify-jwt",
    "deploy:feedback": "supabase functions deploy get-feedback --no-verify-jwt",
    "deploy:publish": "supabase functions deploy publish-activity",
    "deploy:upload-image": "supabase functions deploy upload-image",
    "deploy:train": "node scripts/deploy-train.mjs",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@fontsource/andika": "^5.2.10",
    "@fontsource/atkinson-hyperlegible": "^5.2.8",
    "@fontsource/comic-neue": "^5.2.7",
    "@fontsource/lexend": "^5.2.11",
    "@types/node": "^20.12.0",
    "aws4fetch": "^1.0.20",
    "esbuild": "^0.21.0",
    "prettier": "^3.4.0",
    "prettier-plugin-tailwindcss": "^0.6.10",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
