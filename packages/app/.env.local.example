# Copy this file to .env.local and fill in the actual values.
# .env.local is gitignored (matches *.local in packages/app/.gitignore).
#
# Get these from Supabase dashboard → Project Settings → API.
# The anon key is safe to expose in client code; access is gated by RLS.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Public base for published activity pages. Must match the publish-activity
# Edge Function's R2_PUBLIC_URL_BASE secret. No trailing slash. The editor uses
# it to show a "View published page" link for already-published activities.
VITE_PUBLISHED_URL_BASE=https://pub-xxxxxxxx.r2.dev
