# R2 deploy credentials for `pnpm build:graph-kit` (the calculator kit upload).
# -----------------------------------------------------------------------------
# ONE-TIME SETUP:
#   1. Copy this file to `.env.r2`  (cp .env.r2.example .env.r2)
#   2. Fill in the two secret values below (from the Cloudflare R2 API token)
#   3. From then on just run `pnpm build:graph-kit` — it auto-loads .env.r2
#      (via node --env-file-if-exists). No more pasting creds on every upload.
#
# `.env.r2` is gitignored and never committed. This `.example` twin is safe to
# commit because it holds no secrets. If you rotate the R2 token, update the two
# secret values here in your local .env.r2.
#
# The account id, bucket, and public URL are identifiers, not secrets (they're
# in the public S3 endpoint / the public bucket URL), so they're pre-filled.
# Only the ACCESS KEY ID and SECRET ACCESS KEY are sensitive.

R2_ACCOUNT_ID=d6bd4f28d028fbb4c05c19d1dd895e42
R2_BUCKET_NAME=activity-platform-published
R2_PUBLIC_URL_BASE=https://pub-4675df837c14420c8a996a41027154b1.r2.dev

# --- Fill these two from the Cloudflare R2 token page (S3 client credentials) ---
# Access Key ID  = 32 hex chars.  Secret Access Key = 64 hex chars.
# NOT the "Token value" bearer token — the build script rejects that by shape.
R2_ACCESS_KEY_ID=your_access_key_id_here
R2_SECRET_ACCESS_KEY=your_secret_access_key_here
